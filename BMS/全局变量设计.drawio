<mxfile host="Electron">
  <diagram name="第 1 页" id="FC-YY6EoS6ey5LhmDiAT">
    <mxGraphModel dx="2741" dy="1201" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="GF3O9lkGPdOxWnvzktF5-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=30;fontStyle=1" value="全局变量定义" vertex="1">
          <mxGeometry height="30" width="220" x="60" y="130" as="geometry" />
        </mxCell>
        <mxCell id="GF3O9lkGPdOxWnvzktF5-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;labelBackgroundColor=#E6E6E6;" value="&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;// 电池核心状态（单位：mV/mA/℃/%）&lt;br&gt;typedef struct {&lt;br&gt;    // 电芯电压：13串，每串单位mV，范围0~5000&lt;br&gt;    uint16_t cell_voltage[13];&lt;br&gt;    &lt;br&gt;    // 总电压：单位mV，范围0~65000&lt;br&gt;    uint16_t total_voltage;&lt;br&gt;    &lt;br&gt;    // 电流：单位mA，充电为正，放电为负，范围-32768~32767&lt;br&gt;    int16_t current;&lt;br&gt;    &lt;br&gt;    // NTC温度：2路，单位0.1℃，范围-400~1250（比如250=25.0℃）&lt;br&gt;    int16_t temperature[2];&lt;br&gt;    &lt;br&gt;    // SOC：剩余电量，单位%，范围0~100&lt;br&gt;    uint8_t soc;&lt;br&gt;    &lt;br&gt;    // SOH：电池健康状态，单位%，范围0~100&lt;br&gt;    uint8_t soh;&lt;br&gt;    &lt;br&gt;    // 循环次数：单位次，范围0~65535&lt;br&gt;    uint16_t cycle_count;&lt;br&gt;} Battery_Status_t;&lt;br&gt;&lt;br&gt;// 全局电池状态变量&lt;br&gt;Battery_Status_t g_battery_status;&lt;/span&gt;" vertex="1">
          <mxGeometry height="520" width="520" x="60" y="250" as="geometry" />
        </mxCell>
        <mxCell id="GF3O9lkGPdOxWnvzktF5-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;labelBackgroundColor=#E6E6E6;spacingTop=0;" value="&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;// 故障标志位（0=正常，1=故障）&lt;br&gt;typedef struct {&lt;br&gt;    // 电压类故障&lt;br&gt;    uint8_t over_voltage;       // 过压&lt;br&gt;    uint8_t under_voltage;      // 欠压&lt;br&gt;    uint8_t cell_over_voltage;  // 单电芯过压&lt;br&gt;    uint8_t cell_under_voltage; // 单电芯欠压&lt;br&gt;    &lt;br&gt;    // 电流类故障&lt;br&gt;    uint8_t over_current;       // 过流&lt;br&gt;    uint8_t short_circuit;      // 短路&lt;br&gt;    &lt;br&gt;    // 温度类故障&lt;br&gt;    uint8_t over_temperature;   // 过温&lt;br&gt;    uint8_t under_temperature;  // 低温&lt;br&gt;    &lt;br&gt;    // 综合故障标志：任意故障为1，无故障为0&lt;br&gt;    uint8_t system_fault;&lt;br&gt;} Fault_Status_t;&lt;br&gt;&lt;br&gt;// 全局故障状态变量&lt;br&gt;Fault_Status_t g_fault_status;&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="520" width="330" x="740" y="250" as="geometry" />
        </mxCell>
        <mxCell id="GF3O9lkGPdOxWnvzktF5-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;labelBackgroundColor=#E6E6E6;spacingTop=0;" value="&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;// 充放电控制标志位（0=禁止，1=允许）&lt;br&gt;typedef struct {&lt;br&gt;    uint8_t charge_enable;      // 充电使能&lt;br&gt;    uint8_t discharge_enable;   // 放电使能&lt;br&gt;    &lt;br&gt;    // 当前充放电状态：0=待机，1=充电中，2=放电中，3=保护中&lt;br&gt;    uint8_t charge_discharge_state;&lt;br&gt;} Control_Status_t;&lt;br&gt;&lt;br&gt;// 全局控制状态变量&lt;br&gt;Control_Status_t g_control_status;&lt;/span&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="510" width="480" x="60" y="840" as="geometry" />
        </mxCell>
        <mxCell id="GF3O9lkGPdOxWnvzktF5-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;labelBackgroundColor=#E6E6E6;spacingTop=0;" value="&lt;div&gt;&lt;span style=&quot;font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-size: 16px; white-space: pre;&quot;&gt;// BMS固定配置参数（运行时只读，不用加锁）&lt;br/&gt;typedef struct {&lt;br/&gt;    // 电池参数&lt;br/&gt;    uint16_t cell_count;        // 电芯串数：13&lt;br/&gt;    uint16_t nominal_voltage;   // 标称总电压：48000mV&lt;br/&gt;    uint16_t cell_max_voltage;  // 单电芯最高电压：4200mV&lt;br/&gt;    uint16_t cell_min_voltage;  // 单电芯最低电压：2500mV&lt;br/&gt;    &lt;br/&gt;    // 保护阈值&lt;br/&gt;    uint16_t over_voltage_thr;  // 过压阈值：54600mV（13串×4200mV）&lt;br/&gt;    uint16_t under_voltage_thr; // 欠压阈值：32500mV（13串×2500mV）&lt;br/&gt;    int16_t over_current_thr;   // 过流阈值：50000mA&lt;br/&gt;    int16_t over_temp_thr;      // 过温阈值：600（60.0℃）&lt;br/&gt;    &lt;br/&gt;    // 均衡参数&lt;br/&gt;    uint16_t balance_threshold; // 均衡启动压差：50mV&lt;br/&gt;} BMS_Config_t;&lt;br/&gt;&lt;br/&gt;// 全局配置参数（只读，初始化后不修改）&lt;br/&gt;const BMS_Config_t g_bms_config = {&lt;br/&gt;    .cell_count = 13,&lt;br/&gt;    .nominal_voltage = 48000,&lt;br/&gt;    .cell_max_voltage = 4200,&lt;br/&gt;    .cell_min_voltage = 2500,&lt;br/&gt;    .over_voltage_thr = 54600,&lt;br/&gt;    .under_voltage_thr = 32500,&lt;br/&gt;    .over_current_thr = 50000,&lt;br/&gt;    .over_temp_thr = 600,&lt;br/&gt;    .balance_threshold = 50&lt;br/&gt;};&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="510" width="480" x="730" y="790" as="geometry" />
        </mxCell>
        <mxCell id="GF3O9lkGPdOxWnvzktF5-7" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=25;fontStyle=1" value="电池状态类" vertex="1">
          <mxGeometry height="30" width="220" x="170" y="220" as="geometry" />
        </mxCell>
        <mxCell id="GF3O9lkGPdOxWnvzktF5-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=25;fontStyle=1" value="故障状态类" vertex="1">
          <mxGeometry height="30" width="220" x="780" y="220" as="geometry" />
        </mxCell>
        <mxCell id="GF3O9lkGPdOxWnvzktF5-9" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=25;fontStyle=1" value="控制状态类" vertex="1">
          <mxGeometry height="30" width="220" x="160" y="810" as="geometry" />
