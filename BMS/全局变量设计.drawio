        <mxCell id="GF3O9lkGPdOxWnvzktF5-10" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=25;fontStyle=1" value="配置参数类" vertex="1">
          <mxGeometry height="30" width="220" x="795" y="760" as="geometry" />
        </mxCell>
        <mxCell id="GF3O9lkGPdOxWnvzktF5-11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;" value="" vertex="1">
          <mxGeometry height="1400" width="1350" x="-30" y="90" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
